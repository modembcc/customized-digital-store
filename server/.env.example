# Leave MONGODB_URI unset (or unreachable) and the server falls back to an
# in-memory MongoDB seeded with mock products — good for running the app
# with zero setup, but data will not persist across restarts.
#
# Once you have a real database, copy this file to server/.env and set it,
# e.g. mongodb+srv://<user>:<password>@<cluster>.mongodb.net/customized-digital-store
# MONGODB_URI=mongodb://localhost:27017/customized-digital-store

PORT=5000

# Secret used to sign auth JWTs. If unset, the server falls back to an
# insecure hardcoded development secret (with a console warning) so the app
# still runs with zero setup — set a real random value for anything beyond
# local development.
# JWT_SECRET=replace-with-a-long-random-string

# Origin the client is served from, used for CORS with credentials (cookies).
# Defaults to the Vite dev server if unset.
# CLIENT_ORIGIN=http://localhost:5173
